<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="InputControlsShared.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Odziedziczone kolory systemowe (popup kalendarza, listy systemowe). -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E293B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E2E8F0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1E293B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E2E8F0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#334155" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F8FAFC" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#475569" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#F1F5F9" />

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="TitleBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="SubtitleBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="SectionTitleBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="LabelBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171" />
    <SolidColorBrush x:Key="FooterBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="OverdueRowBrush" Color="#3F1D1D" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#475569" />
    <SolidColorBrush x:Key="ComboBoxPopupHighlightBrush" Color="#334155" />
    <SolidColorBrush x:Key="ComboBoxPopupHighlightTextBrush" Color="#F8FAFC" />

    <SolidColorBrush x:Key="PrimaryActionBackgroundBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="PrimaryActionHoverBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="PrimaryActionPressedBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="PrimaryActionForegroundBrush" Color="#F8FAFC" />

    <Style x:Key="TaskPilotButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource PrimaryActionBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="14"
                                                      ShadowDepth="0"
                                                      Opacity="0.45"
                                                      Color="#60A5FA" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryActionPressedBrush}" />
                            <Setter TargetName="Chrome" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter TargetName="Chrome" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource InputForegroundBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="AlternatingRowBackground" Value="#172033" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>
</ResourceDictionary>
