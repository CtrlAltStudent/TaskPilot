<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F6FA" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TitleBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SubtitleBrush" Color="#64748B" />
    <SolidColorBrush x:Key="SectionTitleBrush" Color="#334155" />
    <SolidColorBrush x:Key="LabelBrush" Color="#475569" />
    <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="FooterBorderBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="OverdueRowBrush" Color="#FFFEF2F2" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#CBD5E1" />

    <Style x:Key="TaskPilotButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinWidth" Value="88" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource FooterBorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource FooterBorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource CardBackgroundBrush}" />
    </Style>
</ResourceDictionary>
