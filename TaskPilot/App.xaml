<Application x:Class="TaskPilot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TaskPilot.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:PriorityDisplayConverter x:Key="PriorityDisplayConverter" />
        <conv:TaskOverdueConverter x:Key="TaskOverdueConverter" />
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Application.Resources>
</Application>
