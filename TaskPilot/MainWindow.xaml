<Window x:Class="TaskPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TaskPilot — menedżer zadań"
        Height="560"
        Width="960"
        MinHeight="420"
        MinWidth="720"
        Background="#F5F6FA">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top"
                Padding="12,10"
                Margin="0,0,0,12"
                Background="White"
                CornerRadius="6">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12"
                                  ShadowDepth="1"
                                  Opacity="0.15"
                                  Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TaskPilot"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#1E293B" />
                    <TextBlock Text="Lista (DataGrid) + formularz edycji • zapis JSON • walidacja tytułu i terminu"
                               FontSize="12"
                               Foreground="#64748B"
                               Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Dodaj zadanie"
                            Command="{Binding AddTaskCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            MinWidth="120" />
                    <Button Content="Usuń"
                            Command="{Binding DeleteTaskCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            MinWidth="88" />
                    <Button Content="Oznacz jako wykonane"
                            Command="{Binding MarkCompleteCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            MinWidth="160" />
                    <Button Content="Zapisz teraz"
                            Command="{Binding SaveNowCommand}"
                            Padding="14,8"
                            MinWidth="110" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                Padding="0,8,0,0"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0">
            <StackPanel>
                <TextBlock Text="{Binding DetailValidationMessage}"
                           Foreground="#DC2626"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="{Binding DetailValidationMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="#64748B"
                           TextWrapping="Wrap"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="6"
                    Padding="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="1"
                                      Opacity="0.12"
                                      Direction="270" />
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Lista zadań (DataGrid)"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#334155"
                               Margin="0,0,0,10" />
                    <DataGrid ItemsSource="{Binding Tasks}"
                              SelectedItem="{Binding SelectedTask}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              IsReadOnly="False"
                              BorderThickness="0">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Converter={StaticResource TaskOverdueConverter}}"
                                                 Value="True">
                                        <Setter Property="Background" Value="#FFFEF2F2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tytuł"
                                                Binding="{Binding Title}"
                                                Width="*"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Termin"
                                                Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                                Width="90"
                                                IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Priorytet"
                                                    Width="90"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="4,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Priority, Converter={StaticResource PriorityDisplayConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Wykonane"
                                                    Binding="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="6"
                    Padding="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="1"
                                      Opacity="0.12"
                                      Direction="270" />
                </Border.Effect>
                <Grid IsEnabled="{Binding IsTaskSelected}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Szczegóły zadania"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#334155"
                               Margin="0,0,0,12" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid DataContext="{Binding SelectedTask}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Tytuł"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,10"
                                       Foreground="#475569" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     Padding="8,6"
                                     MaxLength="200" />

                            <TextBlock Grid.Row="1"
                                       Text="Opis"
                                       VerticalAlignment="Top"
                                       Margin="0,6,12,0"
                                       Foreground="#475569" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="100"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8,6"
                                     Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2"
                                       Text="Termin"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,10"
                                       Foreground="#475569" />
                            <DatePicker Grid.Row="2"
                                        Grid.Column="1"
                                        SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                        Margin="0,0,0,10" />

                            <TextBlock Grid.Row="3"
                                       Text="Priorytet"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,10"
                                       Foreground="#475569" />
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      ItemsSource="{Binding DataContext.PriorityOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Priority}"
                                      Margin="0,0,0,10"
                                      Padding="6,4">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource PriorityDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="4"
                                       Text="Status"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,10"
                                       Foreground="#475569" />
                            <CheckBox Grid.Row="4"
                                      Grid.Column="1"
                                      Content="Wykonane"
                                      IsChecked="{Binding IsCompleted}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,10" />

                            <TextBlock Grid.Row="5"
                                       Text="Identyfikator"
                                       VerticalAlignment="Center"
                                       Foreground="#475569" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Text="{Binding Id}"
                                       VerticalAlignment="Center"
                                       Foreground="#94A3B8"
                                       FontSize="12" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
