<Application x:Class="TaskPilot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TaskPilot.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/AppTheme.xaml" />
                <ResourceDictionary Source="Themes/Animations.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:PriorityDisplayConverter x:Key="PriorityDisplayConverter" />
            <conv:TaskOverdueConverter x:Key="TaskOverdueConverter" />
            <conv:NullOrEmptyToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:ThemeModeDisplayConverter x:Key="ThemeModeDisplayConverter" />
            <conv:TaskStatusFilterDisplayConverter x:Key="TaskStatusFilterDisplayConverter" />
            <conv:TaskPriorityFilterOptionDisplayConverter x:Key="TaskPriorityFilterOptionDisplayConverter" />
            <conv:TaskSortOptionDisplayConverter x:Key="TaskSortOptionDisplayConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
